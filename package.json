{
  "name": "userscript-libs",
  "version": "0.1.4",
  "description": "公共油猴脚本库：封装 GM.xmlHttpRequest / GM.log 等，兼容 ScriptCat 后台/定时脚本",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/prepend-typedef.mjs",
    "watch": "tsc -p tsconfig.json --watch",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "release": "node scripts/release.mjs"
  },
  "license": "MIT",
  "devDependencies": {
    "@toil/gm-types": "^1.0.4",
    "typescript": "^5.5.0"
  }
}
